# JanSahay AI - Environment Variables
# Copy this to .env and fill in production values

# Application
APP_NAME=JanSahay AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://jansahay:jansahay_secret@localhost:5432/jansahay_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=jansahay-change-this-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Google Cloud (Voice Services) - Optional
# GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Twilio (WhatsApp) - Optional
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_WHATSAPP_NUMBER=+14155238886

# AWS
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
S3_BUCKET_NAME=jansahay-assets
